{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "files": ["tests/types.d.ts"],
  "include": ["src/**/*", "tests/**/*", "package.json"],
  "exclude": [
    "node_modules",
    "dist",
    "tests/fixtures/*/dist",
    "tests/fixtures/test-plugin/rspack.config.cjs"
  ]
}
