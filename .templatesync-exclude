# Files copied on `bos init` but never overwritten on `bos sync`.
# These are "user-owned" — the project customizes them after init.

# UI components — project customizes these after init
ui/src/components/**
ui/src/styles.css

# UI routes — only __root.tsx is synced after init; the rest are user-owned
ui/src/routes/_layout/**

# API core business logic — project defines its own API surface and data model
api/src/contract.ts
api/src/index.ts
api/src/db/schema.ts

# Generated contract bridge — always regenerated by bos types gen
ui/src/lib/api-types.gen.ts

# API generated types — always regenerated by bos types gen
api/src/lib/plugins-types.gen.ts
api/src/lib/auth-types.gen.ts
