{
  "name": "monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "api",
      "ui",
      "host",
      "plugins/*"
    ],
    "catalog": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@tanstack/react-query": "5.90.20",
      "@tanstack/react-router": "1.157.16",
      "near-kit": "^0.12.0",
      "@hot-labs/near-connect": "^0.11.0",
      "drizzle-orm": "^0.45.1",
      "drizzle-kit": "^0.31.8",
      "better-auth": "^1.5.4",
      "better-near-auth": "0.5.2",
      "every-plugin": "^2.2.6",
      "everything-dev": "^1.3.7",
      "typescript": "^5.9.3",
      "vitest": "^4.0.17",
      "@libsql/client": "0.17.0",
      "@types/node": "^25.0.3",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "effect": "^3.21.0",
      "@module-federation/enhanced": "0.22.1",
      "@module-federation/node": "2.7.27",
      "@module-federation/rsbuild-plugin": "0.22.1",
      "@module-federation/runtime-core": "0.22.1"
    }
  },
  "scripts": {
    "init": "bun run db:migrate",
    "dev": "everything-dev dev",
    "dev:ui": "everything-dev dev --api remote",
    "dev:api": "everything-dev dev --ui remote",
    "dev:proxy": "everything-dev dev --proxy",
    "build": "everything-dev build",
    "deploy": "everything-dev build --deploy",
    "publish": "everything-dev publish",
    "sync:api-contract": "bun node_modules/everything-dev/src/scripts/sync-api-contract.ts",
    "typecheck": "bun run sync:api-contract & bun run --cwd ui tsc --noEmit & bun run --cwd api tsc --noEmit & bun run --cwd host tsc --noEmit & wait",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "start": "NODE_ENV=production everything-dev start --account ${BOS_ACCOUNT:-dev.everything.near} --domain ${GATEWAY_DOMAIN:-everything.dev} --port ${PORT:-3000} --env ${APP_ENV:-production} --no-interactive",
    "changeset": "changeset",
    "postinstall": "bun node_modules/everything-dev/src/scripts/sync-api-contract.ts",
    "version": "changeset version",
    "release": "echo 'Packages versioned - skipping npm publish'",
    "db:push": "bun run --cwd api drizzle-kit push",
    "db:studio": "bun run --cwd api drizzle-kit studio",
    "db:generate": "bun run --cwd api drizzle-kit generate",
    "db:migrate": "bun run --cwd api drizzle-kit migrate",
    "test": "bun run test:api && bun run test:e2e",
    "test:api": "cd api && bun test tests/integration/ tests/unit/",
    "test:integration": "cd api && bun test tests/integration/",
    "test:e2e": "bun run --cwd host test:e2e"
  },
  "packageManager": "bun@1.2.20",
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "latest",
    "dotenv": "^17.3.1",
    "every-plugin": "catalog:",
    "everything-dev": "catalog:",
    "tsx": "^4.21.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.5.4",
    "@better-auth/passkey": "^1.5.4",
    "@orpc/contract": "^1.13.14"
  },
  "overrides": {
    "axios": "1.13.6"
  }
}
