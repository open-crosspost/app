{
  "name": "@crosspost/twitter",
  "version": "0.0.1",
  "description": "Twitter platform plugin for crosspost",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contract": {
      "types": "./src/contract.ts",
      "default": "./src/contract.ts"
    }
  },
  "dependencies": {
    "@crosspost/plugin": "workspace:*",
    "twitter-api-v2": "^1.27.0",
    "@twitter-api-v2/plugin-rate-limit": "^1.1.0",
    "@orpc/contract": "^1.13.4",
    "@orpc/server": "^1.13.4"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.3",
    "@module-federation/node": "catalog:",
    "@rspack/cli": "^1.6.8",
    "@rspack/core": "^1.6.8",
    "@types/node": "catalog:",
    "dotenv": "^17.2.3",
    "everything-dev": "workspace:*",
    "every-plugin": "workspace:*",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "catalog:",
    "zephyr-rspack-plugin": "0.1.4"
  },
  "scripts": {
    "build": "bun run build:types && rspack build",
    "build:types": "tsc -p tsconfig.contract.json",
    "deploy": "bun run build:types && DEPLOY=true rspack build",
    "dev": "bun run build:types && rspack serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  }
}
