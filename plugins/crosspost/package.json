{
  "name": "@crosspost/plugin",
  "version": "1.0.0",
  "description": "Crosspost plugin for social media cross-posting with NEAR authentication",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contract": {
      "types": "./src/contract.ts",
      "default": "./src/contract.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./platform-contract": {
      "types": "./src/platform-contract.ts",
      "default": "./src/platform-contract.ts"
    }
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@orpc/contract": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "effect": "^3.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.3",
    "@module-federation/node": "^2.7.40",
    "@rspack/cli": "^1.6.8",
    "@rspack/core": "^1.6.8",
    "@types/node": "^25.0.3",
    "dotenv": "^17.2.3",
    "everything-dev": "catalog:",
    "every-plugin": "catalog:",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.17",
    "zephyr-rspack-plugin": "0.1.4"
  },
  "scripts": {
    "build": "bun run build:types && rspack build",
    "build:types": "tsc -p tsconfig.contract.json",
    "deploy": "bun run build:types && DEPLOY=true rspack build",
    "dev": "rspack serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  }
}
